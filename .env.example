# Copy to .env and fill in. These are read at build time by app.config.ts and exposed to the
# app through expo-constants (see lib/env.ts). Both are PUBLIC values — the anon key is safe
# in the bundle. No secret ever goes in this file: the R2 write credential and the Supabase
# service-role key live only in Edge Functions (CLAUDE.md hard rule 4).
#
# The EXPO_PUBLIC_ prefix is required for Expo to expose the var to app.config.ts.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
